# =============================================================================
# CONFIGURACIÓN DE LA API FASTAPI - Global Mantenimiento
# =============================================================================
# IMPORTANTE: Este archivo contiene secrets sensibles
# - NO commitear a repositorio (ya está en .gitignore)
# - Para producción: configurar en Vercel Environment Variables
# =============================================================================

# -----------------------------------------------------------------------------
# VARIABLES REQUERIDAS EN PRODUCCIÓN (Vercel)
# -----------------------------------------------------------------------------
# Las siguientes variables DEBEN configurarse en Vercel Dashboard:
# Settings > Environment Variables

# SECRET_KEY: Clave secreta para firma JWT
# Generar con: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=mi-secreto-super-seguro-para-desarrollo-2024

# DATABASE_URL: URL de conexión a la base de datos PostgreSQL
# Formato: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://neondb_owner:Qrn9BMHFZTC1@ep-spring-thunder-a43zaiw0-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require

# ALLOWED_ORIGINS: Lista de orígenes permitidos para CORS
# Formato: JSON array con las URLs completas de los dominios
# Desarrollo local: ["http://localhost:3000", "http://localhost:3001"]
# Producción Vercel: ["https://tu-proyecto.vercel.app"]
# IMPORTANTE: En producción incluir tanto el dominio con www como sin www si aplica
# Ejemplo producción: ALLOWED_ORIGINS='["https://gm-landin.vercel.app", "https://www.gm-landin.vercel.app"]'
ALLOWED_ORIGINS=["http://localhost:3000", "http://localhost:3001"]

# -----------------------------------------------------------------------------
# VARIABLES OPCIONALES (con valores por defecto seguros)
# -----------------------------------------------------------------------------

# Algoritmo de firma JWT (por defecto: HS256)
ALGORITHM=HS256

# Tiempo de expiración del token JWT en minutos (por defecto: 1440 = 24h)
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Configuración del servidor
HOST=0.0.0.0
PORT=8000

# Modo debug (false en producción)
DEBUG=true
